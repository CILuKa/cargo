class_name TerrainType
extends Resource

## =============================================================================
## 地形类型定义 — Resource类，存储地形类型的静态属性
## =============================================================================
##
## 使用方式：
##   1. 在编辑器中创建TerrainType资源文件（.tres）
##   2. 配置材料、贴图、物理属性等
##   3. 在TerrainManager中注册地形类型
##   4. 通过terrain_type_id引用
##
## 性能优势：
##   - Resource预加载，类型安全
##   - 编辑器友好，可视化配置
##   - 内存共享，相同类型地形共享同一Resource实例
## =============================================================================


# =============================================================================
# 枚举定义
# =============================================================================

## 材料类型（影响生命值、动能伤害等）
enum MaterialType {
	PLASTIC,  # 塑料 - 材料系数25
	WOOD,     # 木材 - 材料系数20
	STONE,    # 石材 - 材料系数30
	METAL     # 金属 - 材料系数30
}

## 地块用途类型（影响交互、碰撞等）
enum TerrainUsage {
	SOLID,        # 实体地块（墙壁、柱子等）
	WALKABLE,     # 可行走地块（地面、平台等）
	INTERACTIVE,  # 可交互地块（门、窗户、机关等）
	HAZARD        # 危险地块（陷阱、熔岩等）
}


# =============================================================================
# 基础属性
# =============================================================================

## 地形类型唯一标识符（用于代码引用）
@export var terrain_type_id: String = ""

## 显示名称
@export var display_name: String = "未命名地形"

## 地块用途类型
@export var usage_type: TerrainUsage = TerrainUsage.WALKABLE


# =============================================================================
# 物理属性
# =============================================================================

## 材料类型（影响生命值和动能伤害）
@export var material_type: MaterialType = MaterialType.STONE

## 质量（千克），影响重力作用和生命值计算
@export var mass: float = 100.0

## 摩擦系数（0-无摩擦，1-正常摩擦，>1-高摩擦）
## 可选字段，不可踩踏地块可以没有该属性（默认为1）
@export var friction_coefficient: float = 1.0


# =============================================================================
# 生命值属性
# =============================================================================

## 是否拥有生命值（某些地块如地面可能不可破坏）
@export var has_health: bool = true

## 自定义生命值（如果为-1，则自动计算：mass * 材料系数）
@export var custom_max_health: int = -1


# =============================================================================
# 交互属性
# =============================================================================

## 是否可被攻击（一般地形只能被能力或撞击伤害，但门/窗户可被选定攻击）
@export var is_attackable: bool = false

## 是否可交互（交互后可转变为另一种地块，如门开关）
@export var is_interactive: bool = false

## 交互后转变的地形类型ID（空字符串表示无转变）
@export var transform_to_id: String = ""


# =============================================================================
# 移动属性
# =============================================================================

## 是否可经过（是否可以站在或通过该地形）
@export var is_passable: bool = true


# =============================================================================
# 贴图属性
# =============================================================================

## 六个面的贴图路径（按Godot Cubemap顺序：+X, -X, +Y, -Y, +Z, -Z）
## 可以是相对路径或绝对路径
@export var texture_paths: Array[String] = [
	"",  # +X (右)
	"",  # -X (左)
	"",  # +Y (上)
	"",  # -Y (下)
	"",  # +Z (前)
	""   # -Z (后)
]


# =============================================================================
# 高度属性
# =============================================================================

## 基础高度（格子数）
@export var base_height: int = 0


# =============================================================================
# 计算属性方法
# =============================================================================

## 获取材料系数（用于生命值计算）
func get_material_coefficient() -> int:
	match material_type:
		MaterialType.PLASTIC:
			return 25
		MaterialType.WOOD:
			return 20
		MaterialType.STONE:
			return 30
		MaterialType.METAL:
			return 30
		_:
			return 20  # 默认木材


## 获取最大生命值（自动计算或使用自定义值）
func get_max_health() -> int:
	if not has_health:
		return 0

	if custom_max_health >= 0:
		return custom_max_health

	# 自动计算：质量 * 材料系数
	return int(mass * get_material_coefficient())


## 获取摩擦系数（如果不可踩踏则返回0）
func get_friction() -> float:
	if not is_passable:
		return 0.0
	return friction_coefficient


## 获取动能伤害抗性（基于材料类型）
func get_kinetic_resistance() -> float:
	match material_type:
		MaterialType.PLASTIC:
			return 0.5   # 塑料容易损坏
		MaterialType.WOOD:
			return 0.7   # 木头一般抗性
		MaterialType.STONE:
			return 1.0   # 石头抗性高
		MaterialType.METAL:
			return 1.5   # 金属抗性最高
		_:
			return 0.7